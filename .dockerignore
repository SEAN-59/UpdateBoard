# ============================================================================
# Docker 빌드 컨텍스트에서 제외할 항목
# COPY . . 실행 시 이미지에 들어가지 않아야 하는 파일/디렉터리
# ============================================================================

# 의존성 (빌드 시 다시 설치함)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js 빌드 산출물 (이미지 안에서 새로 빌드)
.next
out
build
dist

# Git
.git
.gitignore
.gitattributes

# IDE / 에디터
.idea
.vscode
*.swp
*.swo

# OS 메타파일
.DS_Store
Thumbs.db
Desktop.ini

# 환경 변수 (런타임에 주입, 이미지에 포함하면 안 됨)
.env
.env.*

# 로그
*.log
logs

# 로컬 임시 파일
*.tmp
*.bak
*.local

# 비공개 리소스
private
secrets

# Claude / AI 에이전트 로컬 설정
CLAUDE.md
AGENTS.md
.claude

# 문서 (이미지 런타임에 불필요)
README.md

# CI / 배포 설정 (이미지 런타임에 불필요)
Jenkinsfile
compose.yaml
compose.yml
docker-compose.yml
docker-compose.yaml
.dockerignore

# TypeScript 증분 빌드 캐시
*.tsbuildinfo

# 테스트 커버리지
coverage
